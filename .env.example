ANTHROPIC_API_KEY=sk-ant-...
TAVILY_API_KEY=tvly-...
# Optional: cap analyses per cycle (0 = unlimited)
# MAX_ANALYSES_PER_CYCLE=0

# Optional: email notifications via Buttondown (see README "Email notifications")

# NOTIFY_THRESHOLD=70
# DASHBOARD_URL=https://your-app.streamlit.app
# BUTTONDOWN_USERNAME=yourname                 # dashboard: shows the signup form
# BUTTONDOWN_API_KEY=your-buttondown-api-key   # watcher: sends the digest

# Optional: dashboard "Buy me a coffee" button (hidden while unset)
# BMC_SLUG=yourusername
